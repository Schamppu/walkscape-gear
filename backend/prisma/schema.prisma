// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userUuid           String              @id @default(uuid())
  createdAt          DateTime            @default(now())
  stats              PlayerStat[]
  items              OwnedItem[]
  factionReputations FactionReputation[]
}

model PlayerStat {
  userUuid String
  stat     String
  value    Int

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, stat])
}

model OwnedItem {
  userUuid String
  itemId   String
  owned    Boolean
  hidden   Boolean @default(false)
  quality  String?
  quality2 String?

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, itemId])
}

model FactionReputation {
  userUuid   String
  reputation String
  value      Int

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, reputation])
}
